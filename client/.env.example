# API base URL (used by api.js and Vite dev proxy)
VITE_API_BASE_URL=http://localhost:5000
# Alternative keys (same purpose)
VITE_API_URL=http://localhost:5000
# Dev proxy target when VITE_API_BASE_URL/VITE_API_URL not set
VITE_DEV_PROXY_TARGET=http://localhost:5000

# Optional: MIET logo URL (defaults to institutional URL if not set)
# VITE_MIET_LOGO_URL=https://mietjmu.in/wp-content/uploads/2020/02/MIET_LOGO_AUTONOMOUS.webp
